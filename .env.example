# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paddle
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here

# Paddle Price IDs - LATAM (México, Colombia, Argentina, Chile, Perú, etc.)
# Configura precios más bajos para países de Latinoamérica
PADDLE_PRICE_ID_LECTURA_ESENCIAL_LATAM=pri_01xxxxxxxxxxxxx
PADDLE_PRICE_ID_CONSULTA_EVOLUTIVA_LATAM=pri_01xxxxxxxxxxxxx
PADDLE_PRICE_ID_ESPECIAL_PAREJAS_LATAM=pri_01xxxxxxxxxxxxx

# Paddle Price IDs - Internacional (USA, Europa, resto del mundo)
# Configura precios más altos para mercados internacionales
PADDLE_PRICE_ID_LECTURA_ESENCIAL_INTL=pri_01xxxxxxxxxxxxx
PADDLE_PRICE_ID_CONSULTA_EVOLUTIVA_INTL=pri_01xxxxxxxxxxxxx
PADDLE_PRICE_ID_ESPECIAL_PAREJAS_INTL=pri_01xxxxxxxxxxxxx

# AI API (Google Gemini or Claude)
GEMINI_API_KEY=your_gemini_api_key
# or
ANTHROPIC_API_KEY=your_anthropic_api_key

# Email Service (SendGrid or Mailgun)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
